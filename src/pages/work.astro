---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Schema from "@/components/seo/Schema.astro";
import Headline from "@/components/ui/Headline.astro";

const metadata = {
	title: 'Featured Projects | NYC Web Design & Development Portfolio',
	description:
		'Explore the portfolio of NYC web developer Levan Vekua — featuring custom Shopify stores, WordPress sites, and digital platforms for luxury fashion and e-commerce brands.',
};

const portfolioItems = [
  {
    href: "https://www.bonnemaman.us",
    imageSrc: "/img/project-thumbs/bm-thumb-w388.webp",
    imageAlt: "Bonne Maman website design and development by Levan Vekua",
    name: "Bonne Maman",
    role: "UI Design & Development",
    platform: "Magento & WordPress",
    summary:
      "Engineered the digital storefront for this iconic French brand, delivering a high-performance e-commerce experience on Magento with a custom WordPress blog integration.",
  },
  {
    href: "https://www.1000storieswines.com",
    imageSrc: "/img/project-thumbs/1k-thumb-w388.webp",
    imageAlt: "1000 Stories Wines website by Levan Vekua",
    name: "1000 Stories",
    role: "UI Design & Development",
    platform: "WordPress",
    summary:
      "Developed a rich, interactive brand experience for this premium wine brand, featuring complex CMS structures, age-gating, and responsive storytelling layouts.",
  },
  {
    href: "https://www.bonterra.com",
    imageSrc: "/img/project-thumbs/bonterra-thumb-w388.webp",
    imageAlt: "Bonterra organic wines website by Levan Vekua",
    name: "Bonterra",
    role: "UI Design & Development",
    platform: "WordPress",
    summary:
      "Built a performance-optimized WordPress site for this organic winery, translating their sustainability mission into a fast, accessible, and clean user interface.",
  },
  {
    href: "https://www.oaknyc.com",
    imageSrc: "/img/project-thumbs/oak-thumb-w388.webp",
    imageAlt: "OAK NYC fashion e-commerce website by Levan Vekua",
    name: "OAK NYC",
    role: "UI/UX Development",
    platform: "Magento & WordPress",
    summary:
      "Spearheaded the frontend development of this NYC fashion retailer's e-commerce platform, focusing on high-speed mobile performance and streamlined checkout flows.",
  },
  {
    href: "https://www.nililotan.com",
    imageSrc: "/img/project-thumbs/nl-thumb-w388.webp",
    imageAlt: "Nili Lotan luxury fashion website by Levan Vekua",
    name: "Nili Lotan",
    role: "UI/UX Development",
    platform: "Shopify & WordPress",
    summary:
      "Developed a bespoke Shopify Plus experience for this luxury label, featuring high-fidelity editorial layouts, performance tuning, and cross-platform CMS integration.",
  },
  {
    href: "https://www.alexanderwang.com/us-en/projects",
    imageSrc: "/img/project-thumbs/aw-thumb-w388.webp",
    imageAlt: "Alexander Wang fashion brand website by Levan Vekua",
    name: "Alexander Wang",
    role: "UI/UX Development",
    platform: "Demandware",
    summary:
      "Contributed to the frontend architecture of this global fashion house, implementing highly interactive product grids and maintaining rigid design standards.",
  },
  {
    href: "https://jiujiedecor.com",
    imageSrc: "/img/project-thumbs/jj-thumb-w388.webp",
    imageAlt: "Jiu Jie home decor e-commerce website by Levan Vekua",
    name: "Jiu Jie",
    role: "UX/UI Design",
    platform: "Shopify",
    summary:
      "Designed and launched a custom Shopify storefront for this home decor brand, creating a minimal aesthetic that prioritizes visual storytelling and conversion.",
  },
  {
    href: "https://www.standardissuenyc.com",
    imageSrc: "/img/project-thumbs/si-thumb-w388.webp",
    imageAlt: "Standard Issue NYC fashion website by Levan Vekua",
    name: "Standard Issue",
    role: "UI Design",
    platform: "Magento & WordPress",
    summary:
      "Created a scalable design system and frontend templates for this NYC streetwear brand, delivering a performant and brand-aligned e-commerce experience.",
  },
  {
    href: "https://hydenyoo.com",
    imageSrc: "/img/project-thumbs/hy-thumb-w388.webp",
    imageAlt: "Hyden Yoo menswear brand website by Levan Vekua",
    name: "Hyden Yoo",
    role: "UI Design",
    platform: "Magento & WordPress",
    summary:
      "Refined the digital presence of this contemporary menswear label, focusing on editorial-style photography layouts and optimized mobile navigation.",
  },
];
---

<BaseLayout {metadata}>
  <Schema type="BreadcrumbList" data={{ title: "Work", url: Astro.url.pathname }} slot="head" />

  <!-- Portfolio Hero -->
  <section class="py-16 md:py-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <Headline
        title="My Work"
        subtitle="A curated selection of web design and development projects for fashion, food & beverage, and e-commerce brands."
        titleAs="h1"
        classes={{
          container: "max-w-3xl mx-auto text-center mb-8",
          title: "text-4xl md:text-6xl font-bold mb-4",
          subtitle: "text-lg text-muted-foreground",
        }}
      />
      <p class="text-center text-muted-foreground max-w-2xl mx-auto">
        Each project below represents a collaboration where I served as the lead designer, developer,
        or both — delivering custom solutions across Shopify, WordPress, Magento, and more.
      </p>
    </div>
  </section>

  <!-- Portfolio Grid -->
  <section class="pb-16 md:pb-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <ul class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {
          portfolioItems.map((item) => (
            <li class="group relative overflow-hidden rounded-2xl bg-card shadow-sm border border-border/50 hover:shadow-lg transition-all duration-300 transform hover:-translate-y-1">
              <a
                href={item.href}
                target="_blank"
                rel="noopener noreferrer"
                class="block h-full"
              >
                <div class="aspect-video w-full overflow-hidden bg-muted">
                  <img
                    src={item.imageSrc}
                    alt={item.imageAlt}
                    class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                    loading="lazy"
                    width="388"
                    height="218"
                  />
                </div>
                <div class="p-6">
                  <h2 class="text-xl font-bold text-foreground mb-2 group-hover:text-primary transition-colors">
                    {item.name}
                  </h2>
                  <p class="text-sm font-medium text-foreground/80 mb-1">
                    {item.role}
                  </p>
                  <p class="text-xs text-muted-foreground mb-3">
                    {item.platform}
                  </p>
                  <p class="text-sm text-muted-foreground leading-relaxed">
                    {item.summary}
                  </p>
                </div>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- Process CTA -->
  <section class="py-12 md:py-16 border-t border-border">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-muted-foreground mb-4">
        Curious about how these projects came to life?
      </p>
      <a
        href="/about"
        class="inline-flex items-center gap-2 text-sm font-medium text-primary hover:underline"
      >
        Learn about my design & development process →
      </a>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="py-20 md:py-24">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-foreground mb-6">
        Have a Project in Mind?
      </h2>
      <p class="text-lg text-muted-foreground mb-8">
        I'm currently accepting new web design and development projects.
        Whether you need a Shopify store, a WordPress site, or a custom build —
        let's talk about what you need.
      </p>
      <a
        href="/contact"
        class="inline-flex items-center gap-2 rounded-full bg-primary px-10 py-4 text-base font-bold text-primary-foreground hover:bg-primary/90 transition-all hover:scale-[1.02] tracking-tight shadow-lg shadow-primary/20"
      >
        Start a Conversation →
      </a>
    </div>
  </section>
</BaseLayout>
