---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Schema from '@/components/seo/Schema.astro';
import Features from '@/components/widgets/Features.astro';
import Headline from '@/components/ui/Headline.astro';

const metadata = {
	title: 'NYC Web Development Skills | React, Shopify & WordPress',
	description:
		'Technical skills of NYC developer Levan Vekua — React, Next.js, Astro, Shopify Plus, and Performance Optimization for premium e-commerce brands.',
};

const coreSkills = [
	{
		title: 'HTML, CSS & JavaScript',
		description:
			'Semantic HTML5, modern CSS (Flexbox, Grid, animations), and vanilla JavaScript form the foundation of every project. I write clean, accessible, standards-compliant code.',
		icon: 'lucide:code',
		iconClass: 'bg-blue-500/10 text-blue-500',
	},
	{
		title: 'React, Next.js & Astro',
		description:
			'Component-driven architecture for modern web applications. Specialized in Next.js for server-side rendering and Astro for lightweight, content-focused sites with zero-JS overhead.',
		icon: 'lucide:layers',
		iconClass: 'bg-orange-500/10 text-orange-500',
	},
	{
		title: 'Shopify Plus & E-Commerce',
		description:
			'Custom Shopify Plus theme development using Liquid and Hydrogen. I build conversion-optimized stores with seamless app integrations and performance tuning.',
		icon: 'lucide:shopping-cart',
		iconClass: 'bg-green-500/10 text-green-500',
	},
	{
		title: 'WordPress & Headless CMS',
		description:
			'Custom WordPress development with a focus on Guttenberg blocks and headless integrations (WPGraphQL). Scalable content management systems for growing brands.',
		icon: 'lucide:layout',
		iconClass: 'bg-purple-500/10 text-purple-500',
	},
	{
		title: 'Figma & UI/UX Design',
		description:
			'High-fidelity prototyping, design systems, and user flow mapping in Figma. I also work with Photoshop and Illustrator for asset creation and brand collateral.',
		icon: 'lucide:pen-tool',
		iconClass: 'bg-pink-500/10 text-pink-500',
	},
	{
		title: 'Responsive & Accessible Design',
		description:
			'Mobile-first responsive layouts that look great on every device. WCAG-compliant accessible markup ensures your website is usable by everyone.',
		icon: 'lucide:smartphone',
		iconClass: 'bg-cyan-500/10 text-cyan-500',
	},
	{
		title: 'Performance & Core Web Vitals',
		description:
			'Aggressive optimization including image AVIF/WebP conversion, code splitting, and edge caching to ensure lightning-fast loading and top search engine rankings.',
		icon: 'lucide:zap',
		iconClass: 'bg-yellow-500/10 text-yellow-500',
	},
	{
		title: 'Technical SEO & Analytics',
		description:
			'Implementation of Schema.org JSON-LD, semantic HTML5 structure, and sitemap optimization. Integrated with Google Search Console and Analytics for data-driven growth.',
		icon: 'lucide:search',
		iconClass: 'bg-indigo-500/10 text-indigo-500',
	},
	{
		title: 'Git, CI/CD & Deployment',
		description:
			'Version control with Git and GitHub, automated CI/CD pipelines, and deployment to platforms like Vercel, Netlify, and AWS. Streamlined workflows for fast, reliable releases.',
		icon: 'lucide:git-branch',
		iconClass: 'bg-red-500/10 text-red-500',
	},
];
---

<BaseLayout {metadata}>
	<Schema
		type="BreadcrumbList"
		data={{ title: 'Skills', url: Astro.url.pathname }}
		slot="head"
	/>

	<!-- Skills Hero -->
	<section class="pt-16 md:pt-24">
		<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
			<Headline
				title="Skills & Expertise"
				subtitle="With expertise spanning frontend development, e-commerce platforms, and UI/UX design,
        I bring a comprehensive skill set to every project. Here's what I work with daily."
				titleAs="h1"
				classes={{
					container: 'max-w-3xl mx-auto text-center mb-8',
					title: 'text-4xl md:text-6xl font-bold mb-4',
					subtitle: 'text-lg text-muted-foreground',
				}}
			/>
		</div>
	</section>

	<!-- Skills Grid -->
	<section class="pb-16 md:pb-24">
		<Features features={coreSkills} />
	</section>

	<!-- Platforms Section -->
	<section class="py-16 md:py-20 border-t border-border">
		<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
			<h2 class="text-2xl md:text-3xl font-bold text-foreground mb-6">
				Platforms & Frameworks I Work With
			</h2>
			<div class="flex flex-wrap items-center justify-center gap-4">
				{
					[
						'Shopify',
						'WordPress',
						'Webflow',
						'Magento',
						'Next.js',
						'React',
						'Astro',
						'ASP.NET',
						'Figma',
						'Photoshop',
						'Illustrator',
						'Git',
						'Tailwind CSS',
						'SASS',
					].map((tech) => (
						<span class="inline-flex items-center rounded-full border border-border bg-card px-4 py-2 text-sm font-medium text-foreground">
							{tech}
						</span>
					))
				}
			</div>
		</div>
	</section>

	<!-- CTA -->
	<section class="py-20 md:py-24">
		<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
			<h2
				class="text-3xl md:text-4xl font-bold tracking-tight text-foreground mb-6"
			>
				See These Skills in Action
			</h2>
			<p class="text-lg text-muted-foreground mb-8">
				Browse my portfolio to see how I've applied these technologies for
				brands like Alexander Wang, Nili Lotan, and Bonne Maman.
			</p>
			<div class="flex flex-col sm:flex-row items-center justify-center gap-4">
				<a
					href="/work"
					class="inline-flex items-center gap-2 rounded-full bg-primary px-10 py-4 text-base font-bold text-primary-foreground hover:bg-primary/90 transition-all hover:scale-[1.02] tracking-tight shadow-lg shadow-primary/20"
				>
					View Portfolio →
				</a>
				<a
					href="/contact"
					class="inline-flex items-center gap-2 rounded-full border border-border px-10 py-4 text-base font-bold text-foreground hover:bg-muted transition-all hover:scale-[1.02] tracking-tight"
				>
					Discuss a Project
				</a>
			</div>
		</div>
	</section>
</BaseLayout>
